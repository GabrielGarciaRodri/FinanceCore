# URL del backend FinanceCore.API (sin trailing slash).
# El puerto sale de src/FinanceCore.API/Properties/launchSettings.json.
NEXT_PUBLIC_API_URL=http://localhost:5000

# Modo demo pública: banner persistente + credenciales precargadas en el login.
# Las credenciales espejan Identity:Seed:DemoUser del backend (rol Reader).
NEXT_PUBLIC_DEMO_MODE=false
# NEXT_PUBLIC_DEMO_EMAIL=demo@financecore.local
# NEXT_PUBLIC_DEMO_PASSWORD=Demo!2026

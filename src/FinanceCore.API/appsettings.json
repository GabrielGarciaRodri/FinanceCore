{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=financecore;Username=postgres;Password=postgres",
    "HangfireConnection": "Host=localhost;Port=5432;Database=financecore;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  
  "Logging": {
    "EnableSensitiveDataLogging": { "Enabled": false },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Hangfire": "Information"
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Hangfire": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/financecore-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithEnvironmentName"]
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },

  "FinanceCore": {
    "FileIngestion": {
      "InputDirectory": "./data/input",
      "ProcessedDirectory": "./data/processed",
      "ErrorDirectory": "./data/error",
      "SupportedExtensions": [".csv", ".xlsx", ".xls"],
      "MaxFileSizeBytes": 10485760,
      "FileNamePattern": "^[A-Za-z0-9._-]+$"
    },
    
    "Reconciliation": {
      "BalanceTolerance": 0.01,
      "AmountTolerance": 0.01,
      "DateToleranceDays": 2,
      "AutoReconcileAfterClose": true,
      "SignificantDiscrepancyThreshold": 1000.0,
      "SystemProcessor": "SYSTEM"
    },
    
    "ExchangeRates": {
      "Provider": "ExchangeRateApi",
      "BaseUrl": "https://v6.exchangerate-api.com/v6",
      "ApiKey": "",
      "BaseCurrency": "USD",
      "UpdateIntervalHours": 1,
      "CacheDurationMinutes": 60,
      "SupportedCurrencies": ["USD", "EUR", "COP", "MXN", "BRL"],
      "RetryAttempts": 3,
      "TimeoutSeconds": 10
    },
    
    "Processing": {
      "BatchSize": 1000,
      "MaxParallelJobs": 4,
      "TimeoutMinutes": 30
    }
  },

  "AllowedHosts": "*"
}
